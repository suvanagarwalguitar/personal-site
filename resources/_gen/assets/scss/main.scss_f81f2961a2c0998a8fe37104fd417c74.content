.site-nav{background-color:#0b0d0f;border-top:3px solid #6c0e0e;box-shadow:0 0 5px black;position:relative;z-index:100;height:70px}.site-nav.fixed{position:fixed;top:0;left:0;width:100%}.site-nav__inner{position:relative;max-width:1e3px;margin:0 auto;height:100%}.site-nav__links{display:flex;align-items:center;justify-content:center;width:100%;height:100%;list-style:none;margin:0;padding:0}.site-nav__link{font-family:fira sans,helvetica neue,sans-serif;font-size:1rem;color:#f0f0f0;text-decoration:none;display:block;padding:0 1.5rem;line-height:70px;transition:background-color 280ms ease}.site-nav__link:hover{background-color:#000;text-decoration:none}.site-nav__link.active{border-bottom:2px solid #6c0e0e}.site-nav__toggle{display:none;background:0 0;border:none;color:#f0f0f0;font-size:1.2rem;cursor:pointer;padding:.5rem;position:absolute;right:1rem;top:50%;transform:translateY(-50%)}.site-nav__toggle .close-icon{display:none}.site-nav__toggle[aria-expanded=true] .open-icon{display:none}.site-nav__toggle[aria-expanded=true] .close-icon{display:inline}@media(max-width:760px){.site-nav__toggle{display:block}.site-nav__links{display:none;position:absolute;top:70px;left:0;right:0;height:auto;flex-direction:column;background:#0b0d0f;border-top:3px solid #6c0e0e;padding:.5rem 0 1rem}.site-nav__links.is-open{display:flex}.site-nav__links li{width:100%;text-align:center}.site-nav__link{line-height:2.5}}.site-nav-spacer{display:none;height:70px}.site-nav-spacer.visible{display:block}#masthead-spacer{height:350px;width:100%}.masthead-home{font-size:0;background:#000;z-index:-100;position:absolute;top:0;left:0;width:100%;overflow:hidden}.masthead-home__inner{height:350px;position:relative;max-width:1e3px;margin:0 auto}.masthead-home__image{position:absolute;top:0;right:0;width:100%;height:350px;object-fit:cover;object-position:center 20%;display:block}.masthead-home__title{position:absolute;bottom:2rem;left:2rem;font-family:playfair display,Georgia,serif;font-size:clamp(2rem,6vw,4rem);font-weight:700;color:#fff;line-height:1.05;letter-spacing:-.01em;margin:0;text-shadow:0 2px 12px rgba(0,0,0,.6)}#home-main{background:#181a1c;flex:1;display:flex;flex-direction:column}.home-container{background:#181a1c;padding:3rem 0;flex:1;display:flex;flex-direction:column}.home-content{flex:1;width:95%;max-width:1e3px;margin:0 auto;display:flex;flex-direction:row;align-items:flex-start;gap:5rem}@media(max-width:945px){.home-content{flex-direction:column;gap:3rem}}.bio{flex:0 0 260px}@media(max-width:945px){.bio{flex:none;width:100%}}.bio__role{font-family:fira sans,helvetica neue,sans-serif;font-size:.8125rem;letter-spacing:.08em;text-transform:uppercase;color:#939fad;margin:0 0 1.5rem}.bio__text{font-family:fira sans,helvetica neue,sans-serif;font-size:.875rem;line-height:1.65;color:#939fad}.bio__text p{margin:0 0 .5rem}.bio__text p:last-child{margin:0}.event-dock{flex:1;min-width:0}.event-dock__header{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.5rem}.event-dock__title{font-family:playfair display,Georgia,serif;font-size:2rem;font-weight:700;color:#939fad;margin:0;line-height:1}.event-dock__all-link{font-family:fira sans,helvetica neue,sans-serif;font-size:.8125rem;text-transform:uppercase;letter-spacing:.08em;color:#939fad;text-decoration:none}.event-dock__all-link:hover{text-decoration:underline;color:#f0f0f0}.event-dock__cards{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}@media(max-width:945px){.event-dock__cards{grid-template-columns:repeat(2,1fr)}}@media(max-width:500px){.event-dock__cards{grid-template-columns:1fr}}.event-dock__empty{font-size:.8125rem;text-transform:uppercase;letter-spacing:.08em;color:#939fad}.event-card{height:220px;background:#1c2025;display:flex;flex-direction:column;position:relative;transition:transform 280ms ease}.event-card:hover{transform:scale(1.04)}.event-card:hover .event-card__date{background-color:#6c0e0e}.event-card--past{opacity:.5}.event-card__date{background:#242930;height:40px;line-height:40px;font-size:1rem;font-weight:700;text-align:center;padding:0 .5rem;transition:background-color 280ms ease;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#f0f0f0;font-family:fira sans,helvetica neue,sans-serif;display:flex;align-items:center;justify-content:center;gap:.25rem}.event-card__body{flex:1;padding:.5rem 1rem;overflow-y:auto;display:flex;flex-direction:column;gap:.25rem}.event-card__venue{font-family:fira sans,helvetica neue,sans-serif;font-size:.8125rem;color:#f0f0f0;margin:0}.event-card__location{font-family:fira sans,helvetica neue,sans-serif;font-size:.8125rem;color:#939fad;margin:0}.event-card__btn{position:absolute;bottom:.5rem;right:.5rem;font-family:fira sans,helvetica neue,sans-serif;font-size:.75rem;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;color:#f0f0f0;background:#6c0e0e;padding:3px 8px;border-radius:2px;transition:background 150ms ease}.event-card__btn:hover{background:#3f0808;text-decoration:none}.event-card__btn--past,.event-card__btn--tba{background:0 0;color:#939fad;border:1px solid #333}.site-footer{margin-top:auto;background-color:#0b0d0f;color:#939fad;text-align:center;padding:1.5rem 0;font-family:fira sans,helvetica neue,sans-serif;font-size:.8125rem}.site-footer p{margin:0}*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}html{min-height:100%}body{min-height:100vh;min-height:100dvh;display:grid;grid-template-rows:1fr;font-family:fira sans,helvetica neue,sans-serif;font-size:1rem;line-height:1.65;color:#f0f0f0;-webkit-font-smoothing:antialiased}.site-wrapper{min-height:0;display:flex;flex-direction:column}img{max-width:100%;display:block}a{color:inherit}::selection{background:#6c0e0e;color:#fff}