.site-nav{background-color:#0b0d0f;border-top:3px solid #6c3baa;box-shadow:0 0 5px black;position:relative;z-index:100;height:48px}.site-nav.fixed{position:fixed;top:0;left:0;width:100%}.site-nav__inner{position:relative;max-width:1000px;margin:0 auto;height:100%}.site-nav__links{display:flex;align-items:center;justify-content:center;width:100%;height:100%;list-style:none;margin:0;padding:0}.site-nav__link{font-family:lato,helvetica neue,sans-serif;font-size:1rem;color:#f0f0f0;text-decoration:none;display:block;padding:0 1.5rem;line-height:48px;transition:background-color 280ms ease}.site-nav__link:hover{color:#999;text-decoration:none}.site-nav__link.active{border-bottom:2px solid #6c3baa}.site-nav__lang{background:0 0;border:1px solid #333;color:#ddd;font-family:lato,helvetica neue,sans-serif;font-size:.8125rem;padding:2px .5rem;border-radius:3px;cursor:pointer;position:absolute;right:1rem;top:50%;transform:translateY(-50%);transition:color 150ms ease,border-color 150ms ease}.site-nav__lang:hover{color:#f0f0f0;border-color:#f0f0f0}.site-nav__toggle{display:none;background:0 0;border:none;color:#f0f0f0;font-size:1.2rem;cursor:pointer;padding:.5rem;position:absolute;right:1rem;top:50%;transform:translateY(-50%)}.site-nav__toggle .close-icon{display:none}.site-nav__toggle[aria-expanded=true] .open-icon{display:none}.site-nav__toggle[aria-expanded=true] .close-icon{display:inline}@media(max-width:760px){.site-nav__lang{right:3.5rem}.site-nav__toggle{display:block}.site-nav__links{display:none;position:absolute;top:48px;left:0;right:0;height:auto;flex-direction:column;background:#0b0d0f;border-top:3px solid #6c3baa;padding:.5rem 0 1rem}.site-nav__links.is-open{display:flex}.site-nav__links li{width:100%;text-align:center}.site-nav__link{line-height:2.5}}.site-nav-spacer{display:none;height:48px}.site-nav-spacer.visible{display:block}#masthead-spacer{height:440px;width:100%}.masthead-home{font-size:0;background:#000;z-index:-100;position:absolute;top:0;left:0;width:100%;height:440px;overflow:hidden}.masthead-home__inner{height:440px;position:relative;max-width:1000px;margin:0 auto;z-index:1}.masthead-home__image{position:absolute;top:0;left:0;width:100%;height:440px;object-fit:cover;object-position:60% 15%;display:block}@media(min-width:760px){.masthead-home__image{object-position:center 15%}}.masthead-home__title{position:absolute;top:0;bottom:25%;left:2rem;display:flex;flex-direction:column;justify-content:center}@media(min-width:760px){.masthead-home__title{bottom:0}}.masthead-home__name{font-family:lora,Georgia,serif;font-size:clamp(2rem,6vw,4rem);font-weight:400;color:#fff;line-height:1.05;letter-spacing:-.01em;margin:0;text-shadow:0 2px 12px rgba(0,0,0,.6)}.masthead-home__role{font-size:1.25rem;font-style:italic;color:#ddd;margin:-.25em 0 0;text-shadow:0 1px 6px rgba(0,0,0,.6)}.masthead-home__quote{position:absolute;bottom:1rem;left:0;right:0;text-align:center;font-family:lora,Georgia,serif;font-style:italic;font-size:1rem;color:#ddd;text-shadow:0 1px 6px rgba(0,0,0,.6)}#home-main{flex:1;background:#181a1c}.home-container{padding:3rem 0}.home-content{width:95%;max-width:1000px;margin:0 auto;display:flex;flex-direction:column;gap:3rem}.bio{width:100%}.bio__heading{font-family:lora,Georgia,serif;font-size:2rem;font-weight:500;color:#ddd;margin:0 0 1.5rem;line-height:1}.bio__row{display:flex;gap:3rem;align-items:center}@media(max-width:760px){.bio__row{flex-direction:column;gap:2rem}}.bio__text-col{flex:3;min-width:0}@media(max-width:760px){.bio__text-col{flex:none;width:100%}}.bio__text{font-size:.875rem;color:#ddd}.bio__text p{margin:0 0 .5rem}.bio__text p:last-child{margin:0}.contact-box{flex:1;min-width:0;background:#1c2025;border:1px solid #333;border-radius:4px;padding:2rem}@media(max-width:760px){.contact-box{flex:none;width:100%}}.contact-box__heading{font-family:lora,Georgia,serif;font-size:1.5rem;font-weight:500;color:#ddd;margin:0 0 1.5rem;line-height:1}.contact-box__list{list-style:none;display:flex;flex-direction:column;gap:1rem}.contact-box__link{display:flex;align-items:center;gap:.5rem;color:#ddd;text-decoration:none;font-size:.875rem;transition:color 150ms ease}.contact-box__link:hover{color:#f0f0f0}.contact-box__icon{width:1.25em;text-align:center;font-size:1rem}.event-dock{width:100%}.event-dock__header{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.5rem}.event-dock__title{font-family:lora,Georgia,serif;font-size:2rem;font-weight:500;color:#ddd;margin:0;line-height:1}.event-dock__all-link{font-size:.8125rem;text-transform:uppercase;letter-spacing:.08em;color:#ddd;text-decoration:none}.event-dock__all-link:hover{text-decoration:underline;color:#f0f0f0}.event-dock__cards{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}@media(max-width:760px){.event-dock__cards{grid-template-columns:repeat(2,1fr)}}@media(max-width:500px){.event-dock__cards{grid-template-columns:1fr}}.event-dock__cards>[data-lang]{display:contents}.event-dock__cards>[data-lang].lang-hidden{display:none}.event-dock__empty{font-size:.8125rem;text-transform:uppercase;letter-spacing:.08em;color:#ddd}.event-card{height:220px;background:#1c2025;display:flex;flex-direction:column;position:relative;transition:transform 280ms ease}.event-card:hover{transform:scale(1.04)}.event-card:hover .event-card__date{background-color:#6c3baa}.event-card--past{opacity:.5}.event-card__date{background:#242930;height:40px;display:flex;align-items:center;justify-content:center;gap:.25rem;font-family:lato,helvetica neue,sans-serif;font-weight:700;transition:background-color 280ms ease}.event-card__body{flex:1;padding:.5rem 1rem;display:flex;flex-direction:column;gap:.25rem}.event-card__venue{font-size:.8125rem;margin:0}.event-card__location{font-size:.8125rem;color:#ddd;margin:0}.event-card__btn{position:absolute;bottom:.5rem;right:.5rem;font-size:.75rem;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;color:#f0f0f0;background:#6c3baa;padding:3px 8px;border-radius:2px;transition:background 150ms ease}.event-card__btn:hover{background:#542e84;text-decoration:none}.event-card__btn--past,.event-card__btn--tba{background:0 0;color:#ddd;border:1px solid #333}.page-content{width:95%;max-width:1000px;margin:0 auto}.page-content__title{font-family:lora,Georgia,serif;font-size:2rem;font-weight:500;color:#ddd;margin:0 0 2rem;line-height:1;text-align:center}.page-content__body{font-size:1rem;color:#ddd;line-height:1.65;max-width:700px;margin:0 auto}.page-content__body p{margin:0 0 1rem}.page-content__body p:last-child{margin:0}.page-content__body--bio{font-size:.875rem}.page-content__placeholder{font-size:.875rem;color:#ddd;font-style:italic}.events-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}@media(max-width:760px){.events-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:500px){.events-grid{grid-template-columns:1fr}}.events-grid>[data-lang]{display:contents}.events-grid>[data-lang].lang-hidden{display:none}.gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;align-items:start;margin-bottom:3rem}@media(max-width:760px){.gallery{grid-template-columns:repeat(2,1fr)}}@media(max-width:500px){.gallery{grid-template-columns:1fr}}.gallery--portrait{grid-template-columns:repeat(4,1fr)}@media(max-width:760px){.gallery--portrait{grid-template-columns:repeat(3,1fr)}}@media(max-width:500px){.gallery--portrait{grid-template-columns:repeat(2,1fr)}}.gallery__group-title{font-family:lora,Georgia,serif;font-size:1.5rem;font-weight:500;color:#ddd;margin:0 0 1rem}.gallery__item{position:relative}.gallery__item img{width:100%;display:block}.gallery__item .gallery__overlay{position:absolute;bottom:0;left:0;right:0;display:flex;justify-content:space-between;align-items:flex-end;padding:.5rem}.gallery__badge{display:inline-flex;align-items:center;gap:.25rem;background:rgba(0,0,0,.75);color:#ddd;font-size:.7rem;padding:3px 8px;border-radius:4px;pointer-events:auto;text-decoration:none}.gallery__badge--download{color:#f0f0f0;transition:background 150ms ease}.gallery__badge--download:hover{background:rgba(0,0,0,.95)}.gallery__badge--dimensions{font-family:lato,helvetica neue,sans-serif!important}.resume{width:95%;max-width:1000px;margin:0 auto}.resume__header{margin-bottom:1rem}.resume__bio{font-size:.875rem;color:#ddd;line-height:1.65;margin-bottom:2rem}.resume__bio p{margin:0 0 .5rem}.resume__bio p:last-child{margin:0}.resume__last-updated{font-size:.8125rem;font-style:italic;color:#aaa;padding-top:1rem}.resume__name{font-family:lora,Georgia,serif;font-size:clamp(1.75rem,4vw,2.5rem);font-weight:500;color:#f0f0f0;margin:0;line-height:1.15}.resume__pronunciation{font-size:.875rem;color:#ddd;margin:.25rem 0 1rem;color:#aaa}.resume__meta{list-style:none;display:flex;flex-wrap:wrap;gap:.5rem 2rem;font-size:.875rem;font-style:italic;color:#aaa}.resume__section{margin-bottom:3rem}.resume__section-title{font-family:lora,Georgia,serif;font-size:1.5rem;font-weight:500;color:#ddd;margin:0 0 1.5rem;padding-bottom:.5rem;border-bottom:1px solid #333}.resume__entry{display:flex;justify-content:space-between;align-items:baseline;gap:1rem;padding:.5rem 0}@media(max-width:500px){.resume__entry{flex-direction:column;gap:.25rem}}.resume__entry-main{font-size:.875rem;color:#f0f0f0}.resume__entry-note{font-size:.8125rem;color:#ddd;white-space:nowrap}.resume__repertoire-group{margin-bottom:.25rem}.resume__repertoire-group[open] .resume__composer::after{transform:rotate(180deg)}.resume__composer{font-family:lora,Georgia,serif;font-size:1rem;font-weight:500;color:#f0f0f0;padding:.5rem 0;cursor:pointer;list-style:none;display:flex;align-items:center;gap:.5rem}.resume__composer::-webkit-details-marker{display:none}.resume__composer::marker{display:none;content:''}.resume__composer::after{content:'\f078';font-family:'font awesome 7 free';font-weight:900;font-size:.8125rem;color:#ddd;margin-left:auto;transition:transform 150ms ease}.resume__composer:hover{color:#fff}.resume__count{font-family:lato,helvetica neue,sans-serif;font-size:.8125rem;font-weight:400;color:#ddd}.resume__works{list-style:none;padding:0 0 .5rem 1rem}.resume__works li{font-size:.875rem;color:#ddd;padding:2px 0}.reviews{max-width:700px;margin:0 auto}.review{text-align:center;margin:0 0 3rem}.review:last-child{margin-bottom:0}.review__display{font-style:italic;font-size:1.25rem;color:#ddd;line-height:1.65;margin:0}.review__source{font-style:normal;font-size:.875rem;color:#ddd;margin:.5rem 0 0}.review__details{margin-top:1rem}.review__toggle{font-size:.8125rem;color:#ddd;cursor:pointer;list-style:none;text-transform:uppercase;letter-spacing:.08em;transition:color 150ms ease}.review__toggle::-webkit-details-marker{display:none}.review__toggle::marker{display:none;content:''}.review__toggle:hover{color:#f0f0f0}.review__full-wrap{display:grid;grid-template-rows:0fr;opacity:0;transition:grid-template-rows 300ms ease,opacity 300ms ease}.review__full-inner{overflow:hidden}.review__full{font-size:.875rem;color:#ddd;line-height:1.65;font-style:normal;background:#1c2025;border:1px solid #333;border-radius:4px;padding:1.5rem;margin-top:1rem}.review__details[open]>.review__full-wrap{grid-template-rows:1fr;opacity:1}.site-footer{background-color:#0b0d0f;color:#ddd;text-align:center;padding:1.5rem 0;font-size:.8125rem}.site-footer p{margin:0}*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}body{min-height:100vh;min-height:100dvh;font-family:lato,helvetica neue,sans-serif;font-size:1rem;line-height:1.65;color:#f0f0f0;-webkit-font-smoothing:antialiased}.site-wrapper{display:flex;flex-direction:column;min-height:100vh;min-height:100dvh}img{max-width:100%;display:block}a{color:inherit}.lang-hidden{display:none}body.lang-ja{font-family:noto sans jp,sans-serif}body.lang-ja .site-nav__link,body.lang-ja .site-nav__lang{font-family:noto sans jp,sans-serif}body.lang-ja .bio__heading,body.lang-ja .contact-box__heading,body.lang-ja .event-dock__title,body.lang-ja .page-content__title,body.lang-ja .gallery__group-title,body.lang-ja .resume__name,body.lang-ja .resume__section-title,body.lang-ja .review__display,body.lang-ja .masthead-home__role,body.lang-ja .masthead-home__quote{font-family:noto serif jp,serif}::selection{background:#6c3baa;color:#fff}